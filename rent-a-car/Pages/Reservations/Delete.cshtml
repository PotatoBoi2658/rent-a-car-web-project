@page "{id}"
@using rent_a_car.Pages.Reservations
@model DeleteReservationModel
@{
    ViewData["Title"] = "Delete Reservation";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">Confirm Deletion</h4>
                <p>Are you sure you want to delete this reservation?</p>
            </div>

            @if (Model.Reservation != null)
            {
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@Model.Reservation.Car.FullName</h5>
                        <p class="card-text">
                            <strong>Start Date:</strong> @Model.Reservation.StartDate.ToString("yyyy-MM-dd")<br>
                            <strong>End Date:</strong> @Model.Reservation.EndDate.ToString("yyyy-MM-dd")<br>
                            <strong>Total Price:</strong> $@Model.Reservation.TotalPrice.ToString("F2")<br>
                            <strong>Status:</strong> @Model.Reservation.Status
                        </p>
                    </div>
                </div>

                <form method="post" class="mt-3">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a href="/Reservations" class="btn btn-secondary">Cancel</a>
                </form>
            }
            else
            {
                <div class="alert alert-warning">Reservation not found.</div>
            }
        </div>
    </div>
</div>