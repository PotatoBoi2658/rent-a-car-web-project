@page "{id}"
@using rent_a_car.Pages.Cars
@model EditCarModel
@{
    ViewData["Title"] = "Edit Car";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card">
                <div class="card-header">
                    <h2 class="mb-0">@ViewData["Title"]</h2>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <input type="hidden" asp-for="Input.Id" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.Brand" class="form-label">Brand</label>
                                    <input asp-for="Input.Brand" class="form-control" />
                                    <span asp-validation-for="Input.Brand" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.Model" class="form-label">Model</label>
                                    <input asp-for="Input.Model" class="form-control" />
                                    <span asp-validation-for="Input.Model" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.Year" class="form-label">Year</label>
                                    <input asp-for="Input.Year" class="form-control" type="number" />
                                    <span asp-validation-for="Input.Year" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.PassengerSeats" class="form-label">Passenger Seats</label>
                                    <input asp-for="Input.PassengerSeats" class="form-control" type="number" />
                                    <span asp-validation-for="Input.PassengerSeats" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.PricePerDay" class="form-label">Price Per Day ($)</label>
                            <input asp-for="Input.PricePerDay" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="Input.PricePerDay" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label">Description</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">✓ Update Car</button>
                            <a href="/Cars" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}