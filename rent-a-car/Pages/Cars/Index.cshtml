@page
@using rent_a_car.Pages.Cars
@model CarsIndexModel
@{
    ViewData["Title"] = "Browse Cars";
}

<div class="container my-5">
    <div class="row mb-4">
        <div class="col">
            <h1>🚗 @ViewData["Title"]</h1>
        </div>
        @if (User.IsInRole("Administrator"))
        {
            <div class="col text-end">
                <a asp-page="Create" class="btn btn-primary">+ Add New Car</a>
            </div>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Cars.Any())
    {
        <div class="row g-4">
            @foreach (var car in Model.Cars)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card feature-card">
                        <div class="card-body">
                            <h5 class="card-title">@car.FullName</h5>
                            <div class="mb-3">
                                <small class="text-muted">
                                    <strong>Year:</strong> @car.Year | 
                                    <strong>Seats:</strong> @car.PassengerSeats
                                </small>
                            </div>
                            @if (!string.IsNullOrEmpty(car.Description))
                            {
                                <p class="card-text">@car.Description</p>
                            }
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <strong class="h5 mb-0">@car.PricePerDay.ToString("F2")€/day</strong>
                                <div>
                                    
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <a asp-page="Edit" asp-route-id="@car.Id" class="btn btn-warning btn-sm">Edit</a>
                                        <a asp-page="Delete" asp-route-id="@car.Id" class="btn btn-danger btn-sm">Delete</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Check availability -->
            <div class="col-md-6 col-lg-4">
                <div class="card feature-card">
                    <div class="card-body text-center">
                        <span class="feature-icon">📅</span>
                        <h5 class="card-title">Check availability</h5>
                        <p class="card-text">Check availability for your perfect car with just a few clicks.</p>
                        @if (User.Identity?.IsAuthenticated == true)
                        {

                            <a asp-page="/Reservations/CheckAvailability" class="btn btn-primary">Check now</a>
                        }
                        else
                        {
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary">Login to Check</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <strong>No cars available</strong> at the moment. Please check back later!
        </div>
    }
</div>