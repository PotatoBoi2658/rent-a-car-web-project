@page
@using rent_a_car.Pages.Users
@model IndexModel
@{
    ViewData["Title"] = "User Management";
}

<div class="container my-5">
    <div class="row mb-4">
        <div class="col">
            <h1>👥 @ViewData["Title"]</h1>
        </div>
        <div class="col text-end">
            <a asp-page="Create" class="btn btn-primary">+ Add New User</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Users.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Username</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>EGN</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>
                                <strong>@user.UserName</strong>
                            </td>
                            <td>
                                @user.FirstName @user.LastName
                            </td>
                            <td>
                                @user.Email
                            </td>
                            <td>
                                @(string.IsNullOrEmpty(user.PhoneNumber) ? "-" : user.PhoneNumber)
                            </td>
                            <td>
                                @user.EGN
                            </td>
                            <td>
                                @if (await Model.IsAdminAsync(user.Id))
                                {
                                    <span class="badge bg-danger">Administrator</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">User</span>
                                }
                            </td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-page="Delete" asp-route-id="@user.Id" class="btn btn-danger btn-sm">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <strong>No users found.</strong>
        </div>
    }
</div>