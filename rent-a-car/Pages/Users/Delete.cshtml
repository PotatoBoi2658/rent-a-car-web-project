@page "{id}"
@using rent_a_car.Pages.Users
@model DeleteModel
@{
    ViewData["Title"] = "Delete User";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">⚠️ Confirm Deletion</h4>
                <p>Are you sure you want to delete this user? This action cannot be undone.</p>
            </div>

            @if (Model.User != null)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">@Model.User.FirstName @Model.User.LastName</h5>
                        <p class="card-text">
                            <strong>Username:</strong> @Model.User.UserName<br />
                            <strong>Email:</strong> @Model.User.Email<br />
                            <strong>Phone:</strong> @(string.IsNullOrEmpty(Model.User.PhoneNumber) ? "-" : Model.User.PhoneNumber)<br />
                            <strong>EGN:</strong> @Model.User.EGN<br />
                            <strong>Role:</strong> 
                            @if (Model.IsAdmin)
                            {
                                <span class="badge bg-danger">Administrator</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">User</span>
                            }
                        </p>
                    </div>
                </div>

                @if (Model.ReservationCount > 0)
                {
                    <div class="alert alert-warning">
                        <strong>⚠️ Warning:</strong> This user has @Model.ReservationCount active reservation(s). 
                        Deleting this user will also delete all associated reservations.
                    </div>
                }

                <form method="post" class="mt-3">
                    <button type="submit" class="btn btn-danger w-100">Delete User</button>
                    <a asp-page="Index" class="btn btn-secondary w-100 mt-2">Cancel</a>
                </form>
            }
            else
            {
                <div class="alert alert-warning">User not found.</div>
                <a asp-page="Index" class="btn btn-secondary">Back to Users</a>
            }
        </div>
    </div>
</div>